# =============================================================================
# LEADFINDER - CONFIGURATION
# =============================================================================
# Setup:
#   1. cp .env.example .env
#   2. Set your target cities below
#   3. uv run leadfinder scrape
#
# The default data source (Overture Maps open data) is free and needs NO key,
# NO account, and NO billing. A Google Places API key is only required if you
# switch SOURCE to google or both.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED
# -----------------------------------------------------------------------------

# Cities to search. Format: "City State, City State".
#   Example: SEARCH_CITIES=Covington LA, Mandeville LA
SEARCH_CITIES=Covington LA


# -----------------------------------------------------------------------------
# DATA SOURCE
# -----------------------------------------------------------------------------

# overture (default) - free open data, no key/billing; shorter lists, no ratings
# google             - Google Places API (New); best coverage; needs key + billing
# both               - union of the two (Google records win on duplicates)
SOURCE=overture

# Google Places API (New) key. ONLY needed for SOURCE=google or SOURCE=both.
# The key must have "Places API (New)" enabled (distinct from legacy Places API).
# GOOGLE_API_KEY=your_key_here


# -----------------------------------------------------------------------------
# OVERTURE SETTINGS (used when SOURCE=overture or both)
# -----------------------------------------------------------------------------

# Pinned Overture data release (monthly releases; bump deliberately).
OVERTURE_RELEASE=2026-06-17.0

# Drop places below this existence-confidence score (0-1). Higher = cleaner
# but shorter list.
MIN_CONFIDENCE=0.5

# Optional: search this many miles around the city center instead of the city's
# own bounding box. Widen to pull in neighboring areas. Also the `serve` web app
# default radius. Range 1-100.
# RADIUS_MILES=10

# Optional manual bounding box "west,south,east,north". When set, skips
# geocoding and searches exactly this area.
# SEARCH_BBOX=-90.17,30.43,-90.05,30.55


# -----------------------------------------------------------------------------
# GOOGLE SETTINGS (used when SOURCE=google or both)
# -----------------------------------------------------------------------------

# Field profile controls data richness and, therefore, billing SKU.
# Options: essentials | pro | enterprise | atmosphere. websiteUri (the core
# signal) is Enterprise-tier, so the default is enterprise.
FIELD_PROFILE=enterprise

# Results per query. Text Search (New) returns at most 20 per call. Range 1-20.
MAX_RESULTS=20

# Soft ceiling on billable Google calls per calendar month; the run stops when
# reached. Overture queries cost nothing and are not counted.
MONTHLY_CALL_BUDGET=5000

# Optional politeness delay (seconds) between API calls.
REQUEST_DELAY=0.0


# -----------------------------------------------------------------------------
# SHARED SETTINGS
# -----------------------------------------------------------------------------

# Optional: limit to a subset of categories (comma-separated keys). Leave unset
# to search all. Keys: food_beverage, retail, health_wellness,
# professional_services, home_services, automotive, entertainment_recreation,
# education_childcare, events_hospitality, manufacturing_wholesale,
# agriculture_pets, transportation_logistics
# SEARCH_CATEGORIES=food_beverage, home_services

# Output directory for CSV files and the dashboard.
OUTPUT_DIR=leads_output

# Verify stage: concurrent HTTP probes and per-probe timeout (seconds).
PROBE_CONCURRENCY=10
PROBE_TIMEOUT=5.0

# Logging: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
