# =============================================================================
# LEADFINDER - CONFIGURATION
# =============================================================================
# Setup:
#   1. cp .env.example .env
#   2. Add your Google Places API (New) key below
#   3. Set your target cities
#   4. uv run leadfinder scrape
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED
# -----------------------------------------------------------------------------

# Google Places API key. The key MUST have "Places API (New)" enabled -- this is
# a different API from the legacy "Places API". Enable it at:
#   https://console.cloud.google.com/  (APIs & Services -> Enable APIs)
GOOGLE_API_KEY=your_places_api_new_key_here

# Cities to search. Format: "City State, City State".
#   Example: SEARCH_CITIES=Austin TX, Portland OR, Denver CO
SEARCH_CITIES=Austin TX, Portland OR, Denver CO


# -----------------------------------------------------------------------------
# SCRAPE SETTINGS (optional; defaults shown)
# -----------------------------------------------------------------------------

# Field profile. Controls how much data is requested and, therefore, cost.
# The "no website" signal (websiteUri) is an Enterprise-tier field, so the
# default profile is "enterprise". Options: essentials | pro | enterprise | atmosphere
#   - enterprise (default): name, phone, rating, hours, price, websiteUri, ...
#   - atmosphere: adds service attributes (serves_beer, takeout, ...) at higher cost
FIELD_PROFILE=enterprise

# Optional: limit to a subset of categories (comma-separated keys). Leave unset
# to search all categories. Keys: food_beverage, retail, health_wellness,
# professional_services, home_services, automotive, entertainment_recreation,
# education_childcare, events_hospitality, manufacturing_wholesale,
# agriculture_pets, transportation_logistics
# SEARCH_CATEGORIES=food_beverage, home_services

# Results per query. Text Search (New) returns at most 20 per call and does not
# paginate; coverage comes from the keyword x city fan-out. Range: 1-20.
MAX_RESULTS=20

# Output directory for CSV files.
OUTPUT_DIR=leads_output

# Optional politeness delay (seconds) between API calls.
REQUEST_DELAY=0.0


# -----------------------------------------------------------------------------
# COST CONTROL (optional)
# -----------------------------------------------------------------------------

# Soft ceiling on billable Text Search calls per calendar month. The run stops
# when this is reached. A full sweep of all categories can be thousands of calls,
# so keep this aligned with your budget.
#
# Pricing note (2026): Google bills per SKU with per-SKU monthly free tiers
# (~1,000 free Enterprise calls/month). Billing is by field mask: the highest-
# tier field requested sets the SKU for the whole call. leadfinder prints a
# pre-flight cost estimate before each run.
MONTHLY_CALL_BUDGET=5000


# -----------------------------------------------------------------------------
# VERIFY SETTINGS (optional)
# -----------------------------------------------------------------------------

# Concurrent HTTP probes when verifying candidate domains.
PROBE_CONCURRENCY=10

# Per-probe timeout (seconds).
PROBE_TIMEOUT=5.0


# -----------------------------------------------------------------------------
# LOGGING (optional)
# -----------------------------------------------------------------------------

# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
